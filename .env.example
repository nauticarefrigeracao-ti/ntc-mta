# Copie para .env (ou exporte como variáveis de ambiente) e preencha.
# NUNCA commite o arquivo .env.

# Postgres (Neon) — obrigatório
ML_NEON_URL=postgresql://usuario:senha@host/db?sslmode=require

# Token Mercado Livre — opcional (por padrão é lido do Neon, auto-rotacionado)
ML_ACCESS_TOKEN=

# Token Tiny ERP — opcional (usado para CMV por SKU)
TINY_TOKEN=
